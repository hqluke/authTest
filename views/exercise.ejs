<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <title>Exercise Selection</title>
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="stylesheet" href="/exercise.css" />
    </head>
    <body>
        <div class="container">
            <div class="eHeader">
                <h1>Add Workout</h1>
                <p class="date-subtitle" id="dateDisplay">Loading...</p>
            </div>
            <div class="button-container">
                <a href="#" id="upperLink">
                    <button class="exercise-button upper-button">
                        <span class="emoji">💪</span>
                        <span class="button-text">Upper Body</span>
                    </button>
                </a>
                <a href="#" id="lowerLink">
                    <button class="exercise-button lower-button">
                        <span class="emoji">🦵</span>
                        <span class="button-text">Lower Body</span>
                    </button>
                </a>
                <a href="#" id="runLink">
                    <button class="exercise-button run-button">
                        <span class="emoji">🏃</span>
                        <span class="button-text">Run</span>
                    </button>
                </a>
            </div>
            <div class="bottom-buttons">
                <a href="/">
                    <button class="back-button">← Back to Home</button>
                </a>
                <a href="#" id="viewDayBtn">
                    <button class="back-button" id="viewDayBtnText">View Day</button>
                </a>
                <a href="/log-out">
                    <button class="logout-button">Log Out</button>
                </a>
            </div>
        </div>
        
        <script>
            // Get URL parameters
            const urlParams = new URLSearchParams(window.location.search);
            let pageYear = parseInt(urlParams.get('year'));
            let pageMonth = parseInt(urlParams.get('month'));
            let pageDay = parseInt(urlParams.get('day'));
            
            // If no date in URL, use today's date (client timezone)
            if (!pageYear || !pageMonth || !pageDay) {
                const today = new Date();
                pageYear = today.getFullYear();
                pageMonth = today.getMonth() + 1;
                pageDay = today.getDate();
            }
            
            // Get today's date for comparison
            const today = new Date();
            const todayYear = today.getFullYear();
            const todayMonth = today.getMonth() + 1;
            const todayDay = today.getDate();
            
            // Check if page date matches today
            const isToday = (pageYear === todayYear && pageMonth === todayMonth && pageDay === todayDay);
            
            // Update date display
            document.getElementById('dateDisplay').textContent = `${pageMonth}/${pageDay}/${pageYear}`;
            
            // Update button text
            const btnText = document.getElementById('viewDayBtnText');
            if (isToday) {
                btnText.textContent = 'View Today';
            } else {
                btnText.textContent = `View ${pageMonth}/${pageDay}${pageYear !== todayYear ? ` ${pageYear}` : ''}`;
            }
            
            // Update all links with correct date
            const dateParams = `year=${pageYear}&month=${pageMonth}&day=${pageDay}`;
            
            document.getElementById('upperLink').href = `/exercise/upper?${dateParams}`;
            document.getElementById('lowerLink').href = `/exercise/lower?${dateParams}`;
            document.getElementById('runLink').href = `/exercise/run?${dateParams}`;
            document.getElementById('viewDayBtn').href = `/calendar?${dateParams}`;
        </script>
    </body>
</html>
