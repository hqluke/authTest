<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Workout Tracker - Login</title>
        <link rel="stylesheet" href="/index.css" />
    </head>
    <body>
        <div class="container">
            <div class="header">
                <h1>Workout Tracker</h1>
                <p class="tagline">U Mirin' Brah?</p>
            </div>
            <% if (currentUser) { %>
                <div class="welcome-section">
                    <h2>Welcome back, <%= currentUser.name %>!</h2>
                    <div class="button-group">
                        <a href="/exercise">
                            <button class="btn-primary">Enter Workout</button>
                        </a>
                        <a href="#" id="viewTodayBtn">
                            <button class="btn-today">View Today</button>
                        </a>
                        <a href="/calendar">
                            <button class="btn-secondary">View Calendar</button>
                        </a>
                        <a href="/log-out">
                            <button class="btn-logout">Log Out</button>
                        </a>
                    </div>
                </div>
                
                <script>
                    // Calculate today's date in user's local timezone
                    document.getElementById('viewTodayBtn').addEventListener('click', function(e) {
                        e.preventDefault();
                        const today = new Date();
                        const year = today.getFullYear();
                        const month = today.getMonth() + 1;
                        const day = today.getDate();
                        window.location.href = `/calendar?year=${year}&month=${month}&day=${day}`;
                    });
                </script>
            <% } else { %>
                <div class="login-section">
                    <h2>Sign In</h2>
                    <form action="/log-in" method="POST" class="login-form">
                        <div class="form-group">
                            <label for="username">Username</label>
                            <input 
                                type="text" 
                                id="username" 
                                name="username" 
                                placeholder="Enter your username"
                                required
                            />
                        </div>
                        <div class="form-group">
                            <label for="password">Password</label>
                            <input 
                                type="password" 
                                id="password" 
                                name="password" 
                                placeholder="Enter your password"
                                required
                            />
                        </div>
                        <button type="submit" class="btn-login">Sign In</button>
                    </form>
                    
                    <div class="demo-section">
                        <p>Just want to try it out?</p>
                        <a href="/demo">
                            <button class="btn-demo">Try Demo Account</button>
                        </a>
                    </div>
                    
                    <div class="signup-link">
                        <p>Don't have an account?</p>
                        <a href="/sign-up">
                            <button class="btn-signup">Create Account</button>
                        </a>
                    </div>
                </div>
            <% } %>
        </div>
    </body>
</html>
